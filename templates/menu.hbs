<div class="cat-dialog-shell">
<header class="cat-dialog-header">
    <span class="cat-dialog-title">{{localize title}}</span>
    <button type="button" class="cat-app-header-button" data-action="close" data-tooltip="{{localize 'Close'}}" aria-label="{{localize 'Close'}}">
        <i class="fas fa-xmark" aria-hidden="true"></i>
    </button>
</header>
<div id="menu-app" class="cat-dialog-body standard-form scrollable">
    {{#if tabbed}}
    <nav class="cat-menu-tabs">
        {{#each inputs}}
            <a class="cat-menu-tab{{#if @first}} active{{/if}}" data-tab="{{name}}">{{label}}</a>
        {{/each}}
    </nav>
    {{/if}}
    {{#each inputs}}
        {{#if ../tabbed}}<section class="cat-menu-tab-panel{{#if @first}} active{{/if}}" data-tab-panel="{{name}}">{{/if}}
        {{#if useHelper}}
            {{#each options}}
                {{formGroup field name=name value=value}}
            {{/each}}
        {{else if isPriority}}
            <div class="cat-settings-priority" data-source-setting="{{name}}" data-pack-setting="{{packSetting}}">
                {{#unless ../tabbed}}{{#if label}}<h3 class="cat-priority-label">{{label}}</h3>{{/if}}{{/unless}}
                {{#if hint}}<p class="hint">{{hint}}</p>{{/if}}
                <ul class="cat-priority-list" data-list="enabled">
                    {{#each enabledRows}}
                        <li class="cat-priority-row" draggable="true" data-source-id="{{id}}" data-kind="{{kind}}">
                            <span class="cat-source-pill cat-source-pill-{{kind}}">{{kindLabel}}</span>
                            <span class="cat-priority-name">{{name}}</span>
                            <input type="number" class="cat-priority-rank" value="{{priority}}" draggable="false">
                            <button type="button" class="cat-priority-toggle" draggable="false" data-priority-action="disable" data-tooltip="{{localize 'CAT.Settings.AutomationSources.Disable'}}" aria-label="{{localize 'CAT.Settings.AutomationSources.Disable'}}">
                                <i class="fas fa-xmark" aria-hidden="true"></i>
                            </button>
                        </li>
                    {{/each}}
                </ul>
                <details class="cat-priority-disabled-section">
                    <summary>{{localize "CAT.Settings.AutomationSources.Disabled"}} (<span class="cat-priority-disabled-count">{{disabledRows.length}}</span>)</summary>
                    <ul class="cat-priority-list cat-priority-disabled" data-list="disabled">
                        {{#each disabledRows}}
                            <li class="cat-priority-row" data-source-id="{{id}}" data-kind="{{kind}}">
                                <span class="cat-source-pill cat-source-pill-{{kind}}">{{kindLabel}}</span>
                                <span class="cat-priority-name">{{name}}</span>
                                <input type="number" class="cat-priority-rank" value="{{priority}}" draggable="false" hidden>
                                <button type="button" class="cat-priority-toggle" draggable="false" data-priority-action="enable" data-tooltip="{{localize 'CAT.Settings.AutomationSources.Enable'}}" aria-label="{{localize 'CAT.Settings.AutomationSources.Enable'}}">
                                    <i class="fas fa-plus" aria-hidden="true"></i>
                                </button>
                            </li>
                        {{/each}}
                    </ul>
                </details>
            </div>
        {{/if}}
        {{#if ../tabbed}}</section>{{/if}}
    {{/each}}
</div>
{{#if buttons.length}}
<footer class="cat-dialog-footer">
    {{#each buttons}}
        <button type="submit" name="{{name}}">{{localize label}}</button>
    {{/each}}
</footer>
{{/if}}
</div>
