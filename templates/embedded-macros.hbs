<div class="cat-embedded-macros-shell">
    <header class="cat-embedded-macros-header">
        <span class="cat-embedded-macros-title">{{title}}</span>
        <button type="button" class="cat-medkit-close" data-action="close" data-tooltip="{{localize 'Close'}}" aria-label="{{localize 'Close'}}">
            <i class="fas fa-xmark" aria-hidden="true"></i>
        </button>
    </header>

    <div class="cat-embedded-macros-body">
        <div class="standard-form">
            {{#each inputs as |input key|}}
                {{formGroup input.field value=input.value name=key}}
            {{/each}}
        </div>
    </div>

    <footer class="cat-embedded-macros-footer">
        <button type="button" data-action="close" data-tooltip="{{localize 'CAT.MEDKIT.Footer.CancelTooltip'}}">
            <i class="fa-solid fa-xmark"></i>
            {{localize "CAT.MEDKIT.Footer.Cancel"}}
        </button>
        <button type="button" data-action="confirm">
            <i class="fa-solid fa-check"></i>
            {{localize "DND5E.Confirm"}}
        </button>
    </footer>
</div>
