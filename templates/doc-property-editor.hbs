<div class="cat-embedded-macros-shell">
    <header class="cat-embedded-macros-header">
        <i class="fa-solid fa-shield-cat cat-dialog-icon" aria-hidden="true"></i>
        <span class="cat-embedded-macros-title">{{title}}</span>
        <button type="button" class="cat-app-header-button cat-medkit-header-button" data-action="close" data-tooltip="{{localize 'Close'}}" aria-label="{{localize 'Close'}}">
            <i class="fas fa-xmark" aria-hidden="true"></i>
        </button>
    </header>

    <div class="cat-embedded-macros-body">
        <div class="standard-form">
            {{#if valueChoices}}
                <div class="form-group">
                    <label for="cat-docprop-value">{{valueLabel}}</label>
                    <div class="form-fields">
                        <cat-multi-combobox input-id="cat-docprop-value" name="{{valuePath}}">
                            {{#each valueChoices}}
                                <option value="{{value}}"{{#if selected}} selected{{/if}}>{{label}}</option>
                            {{/each}}
                        </cat-multi-combobox>
                    </div>
                    <p class="hint">{{valueHint}}</p>
                </div>
            {{else}}
                {{formGroup valueField value=value name=valuePath hint=valueHint label=valueLabel}}
            {{/if}}
            <fieldset>
                <legend>{{localize "CAT.MEDKIT.DocProps.Restrictions.Legend"}}</legend>
                <p>{{localize "CAT.MEDKIT.DocProps.Restrictions.Hint"}}</p>
                {{#each restrictions as |r|}}
                    {{#if r.options}}
                        <div class="form-group">
                            <label for="cat-docprop-{{r.key}}">{{r.label}}</label>
                            <div class="form-fields">
                                <cat-multi-combobox input-id="cat-docprop-{{r.key}}" name="{{r.valuePath}}">
                                    {{#each r.options}}
                                        <option value="{{value}}"{{#if selected}} selected{{/if}}>{{label}}</option>
                                    {{/each}}
                                </cat-multi-combobox>
                            </div>
                            <div class="cat-docprop-toggles">
                                {{#if r.requireAllPath}}
                                    <label class="checkbox cat-docprop-requireall">
                                        <input type="checkbox" name="{{r.requireAllPath}}" {{#if r.requireAll}}checked{{/if}}>
                                        <span id="cat-docprop-requireAllLabel-{{r.key}}">{{r.requireAllLabel}}</span>
                                    </label>
                                {{/if}}
                                {{#if r.invertPath}}
                                    <label class="checkbox cat-docprop-requireall">
                                        <input class="cat-docprop-invert" type="checkbox" name="{{r.invertPath}}" {{#if r.invert}}checked{{/if}}>
                                        {{localize "CAT.MEDKIT.DocProps.Restrictions.Invert"}}
                                    </label>
                                {{/if}}
                            </div>
                            <p class="hint" id="cat-docprop-hint-{{r.key}}">{{r.hint}}</p>
                        </div>
                    {{else}}
                        {{formGroup r.field value=r.value name=r.valuePath hint=r.hint label=r.label}}
                    {{/if}}
                {{/each}}
            </fieldset>
        </div>
    </div>

    <footer class="cat-embedded-macros-footer">
        <button type="button" data-action="close" data-tooltip="{{localize 'CAT.MEDKIT.Footer.CancelTooltip'}}">
            <i class="fa-solid fa-xmark"></i>
            {{localize "CAT.MEDKIT.Footer.Cancel"}}
        </button>
        <button type="submit">
            <i class="fa-solid fa-check"></i>
            {{localize "DND5E.Confirm"}}
        </button>
    </footer>
</div>
